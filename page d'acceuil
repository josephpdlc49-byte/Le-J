<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RoboArchive — Archive FRC & ECAM</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css"/>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background-color: #003366; color: #1a1a18; }
    .header { background: rgba(67, 27, 230, 0.92); padding: 1.5rem; border-bottom: 1px solid #dbeafe; backdrop-filter: blur(10px); }
    .logo { display: flex; align-items: center; gap: 12px; margin-bottom: 1rem; }
    .logo-icon { width: 60px; height: 60px; border-radius: 18px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #003366; }
    .logo-icon img { width: 100%; height: 100%; object-fit: contain; display: block; }
    .logo-title { font-size: 20px; font-weight: 700; color: #003366; }
    .logo-sub { font-size: 13px; color: #475569; }
    .nav { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; margin-top: 1rem; }
    .nav-btn { font-size: 13px; padding: 10px 16px; border: 1px solid #cbd5e1; border-radius: 999px; background: #fff; color: #475569; cursor: pointer; text-decoration: none; transition: transform 0.15s ease, background-color 0.15s ease; }
    .nav-btn:hover { transform: translateY(-1px); }
    .nav-btn.active { background: #003366; color: #fff; border-color: transparent; }
    .year-filter { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; padding: 1rem 1.5rem; }
    .year-title { font-size: 14px; color: #334155; font-weight: 700; }
    .year-btn { font-size: 12px; padding: 8px 14px; border: 1px solid #cbd5e1; border-radius: 999px; background: #fff; color: #475569; text-decoration: none; }
    .year-btn.active { background: #cfe2ff; color: #003366; border-color: transparent; }
    .hero { padding: 0 1.5rem 1.5rem; }
    .hero-title { font-size: 32px; margin-bottom: 0.5rem; color: #0f172a; }
    .hero-text { max-width: 720px; color: #475569; line-height: 1.7; }
    .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; padding: 0 1.5rem 1.5rem; }
    .stat { background: white; border-radius: 18px; padding: 18px 16px; box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04); }
    .stat-num { font-size: 28px; font-weight: 700; color: #0f172a; }
    .stat-label { font-size: 12px; color: #64748b; margin-top: 4px; letter-spacing: 0.02em; text-transform: uppercase; }
    .grid { background: #003366; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; padding: 0 1.5rem 2rem; }
    .robot-card { background: white; border: 1px solid #e2e8f0; border-radius: 18px; overflow: hidden; text-decoration: none; color: inherit; display: block; transition: transform 0.15s ease, box-shadow 0.15s ease; }
    .robot-card:hover { transform: translateY(-2px); box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08); }
    .robot-img { width: 100%; height: 140px; background: linear-gradient(135deg, #eef2ff 0%, #ffffff 100%); display: flex; align-items: center; justify-content: center; }
    .robot-img i { font-size: 42px; color: #64748b; opacity: 0.45; }
    .robot-body { padding: 18px 16px; }
    .robot-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
    .robot-name { font-size: 16px; font-weight: 700; color: #0f172a; }
    .comp-badge { font-size: 11px; padding: 4px 12px; border-radius: 999px; font-weight: 700; text-transform: uppercase; }
    .badge-FRC  { background: #e0f2ff; color: #0c4a6e; }
    .badge-FTC  { background: #fff1df; color: #b45309; }
    .badge-ECAM { background: #ecfdf5; color: #166534; }
    .robot-meta { font-size: 13px; color: #64748b; display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
    .rank { display: flex; align-items: center; gap: 6px; font-size: 13px; color: #475569; }
    .rank i { font-size: 14px; color: #d97706; }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="header">
    <div class="logo">
      <div class="logo-icon">
        <img src="{{ url_for('template_logo') }}" alt="Logo RoboArchive" onerror="this.style.display='none'" />
      </div>
      <div>
        <div class="logo-title">RoboArchive</div>
        <div class="logo-sub">Archive FTC & ECAM</div>
      </div>
    </div>
    <div class="nav">
      <a href="/" class="nav-btn {% if active_page == 'home' %}active{% endif %}">Tous les robots</a>
      <a href="/classements" class="nav-btn {% if active_page == 'classements' %}active{% endif %}">Classements</a>
      <a href="/forum" class="nav-btn {% if active_page == 'forum' %}active{% endif %}">Forum</a>
      <a href="/contacts" class="nav-btn {% if active_page == 'contacts' %}active{% endif %}">Contacts</a>
    </div>
    <div class="hero">
      <div class="hero-title">Tous les robots</div>
      <div class="hero-text">Parcourez facilement les fiches de robots, filtrez par année et trouvez rapidement les meilleurs profils.</div>
    </div>
    <div class="year-filter">
      <div class="year-title">Années</div>
      <a href="/" class="year-btn {% if not selected_year %}active{% endif %}">Tous</a>
      {% for year in years %}
      <a href="/?annee={{ year }}" class="year-btn {% if selected_year == year %}active{% endif %}">{{ year }}</a>
      {% endfor %}
    </div>
  </div>

  <!-- Stats -->
  <div class="stats">
    <div class="stat">
      <div class="stat-num">{{ robots | length }}</div>
      <div class="stat-label">Robots archivés</div>
    </div>
    <div class="stat">
      <div class="stat-num">{{ robots | map(attribute='annee') | unique | list | length }}</div>
      <div class="stat-label">Années</div>
    </div>
  </div>

  <!-- Grille robots -->
  <div class="grid">

    {% for robot in robots %}
    <a href="/robot/{{ robot.id }}" class="robot-card">
      <div class="robot-img"><i class="ti ti-robot"></i></div>
      <div class="robot-body">
        <div class="robot-header">
          <div class="robot-name">{{ robot.nom }}</div>
          <span class="comp-badge badge-{{ robot.competition }}">{{ robot.competition }}</span>
        </div>
        <div class="robot-meta"><i class="ti ti-calendar" style="font-size:13px"></i> {{ robot.annee }}</div>
        <div class="rank"><i class="ti ti-trophy"></i><span>{{ robot.classement }}e place</span></div>
      </div>
    </a>
    {% endfor %}

  </div>

</body>
</html>
