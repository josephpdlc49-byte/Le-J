<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Détails du robot</title>
  <style>
    body { font-family: system-ui, sans-serif; background: #f5f5f3; color: #1a1a18; margin: 0; padding: 1.5rem; }
    .card { max-width: 720px; margin: 0 auto; background: white; border-radius: 16px; padding: 1.5rem; box-shadow: 0 12px 25px rgba(0,0,0,0.08); }
    .title { font-size: 26px; margin-bottom: 0.5rem; }
    .meta { color: #888780; margin-bottom: 1.25rem; }
    .description { line-height: 1.7; margin-bottom: 1.5rem; }
    .back { display: inline-block; padding: 0.8rem 1.2rem; border-radius: 10px; border: 1px solid #d3d1c7; text-decoration: none; color: #185FA5; }
  </style>
</head>
<body>
  <div class="card">
    <div class="title">{{ robot.nom }}</div>
    <div class="meta">Équipe : {{ robot.equipe }} · Année : {{ robot.annee }} · compétition : {{ robot.competition }}</div>
    <div class="description">{{ robot.description }}</div>
    <div class="description"><strong>Classement :</strong> {{ robot.classement }}e place</div>
    <a href="/" class="back">Retour à l'accueil</a>
  </div>
</body>
</html>
