<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Classements — RoboArchive</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f5f5f3; color: #1a1a18; }
    .header { background: white; padding: 1.5rem; border-bottom: 1px solid #e0ded8; }
    .logo { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; }
    .logo-icon { width: 60px; height: 60px; border-radius: 14px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #185FA5; }
    .logo-icon img { width: 100%; height: 100%; object-fit: contain; display: block; }
    .logo-title { font-size: 18px; font-weight: 500; }
    .logo-sub { font-size: 13px; color: #888780; }
    .nav { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
    .nav-btn { font-size: 13px; padding: 6px 14px; border: 1px solid #d3d1c7; border-radius: 8px; background: transparent; color: #888780; cursor: pointer; text-decoration: none; }
    .nav-btn.active { background: #e6f1fb; color: #185FA5; border-color: transparent; }
    .nav-btn.login { margin-left: auto; border-color: #185FA5; color: #185FA5; }
    .content { max-width: 900px; margin: 1.5rem auto; padding: 0 1.5rem; }
    .table { width: 100%; border-collapse: collapse; background: white; border: 1px solid #e0ded8; border-radius: 16px; overflow: hidden; }
    .table th, .table td { padding: 14px 16px; text-align: left; border-bottom: 1px solid #f0eeeb; }
    .table th { background: #f9f8f5; color: #55523f; font-weight: 600; }
    .table tr:last-child td { border-bottom: none; }
    .robot-name { font-weight: 600; }
    .badge-FTC { background: #FFF3E0; color: #E65100; padding: 3px 10px; border-radius: 999px; font-size: 12px; }
  </style>
</head>
<body>
  <div class="header">
    <div class="logo">
      <div class="logo-icon">
        <img src="{{ url_for('template_logo') }}" alt="Logo RoboArchive" onerror="this.style.display='none'" />
      </div>
      <div>
        <div class="logo-title">RoboArchive</div>
        <div class="logo-sub">Archive FTC & ECAM</div>
      </div>
    </div>
    <div class="nav">
      <a href="/" class="nav-btn {% if active_page == 'home' %}active{% endif %}">Tous les robots</a>
      <a href="/classements" class="nav-btn {% if active_page == 'classements' %}active{% endif %}">Classements</a>
      <a href="/forum" class="nav-btn {% if active_page == 'forum' %}active{% endif %}">Forum</a>
      <a href="/contacts" class="nav-btn {% if active_page == 'contacts' %}active{% endif %}">Contacts</a>
    </div>
  </div>
  <div class="content">
    <div class="hero">
      <div class="hero-title">Classements</div>
      <div class="hero-text">Visualisez les meilleures performances des robots classés par place et compétition.</div>
    </div>
    <table class="table">
      <thead>
        <tr>
          <th>Place</th>
          <th>Nom</th>
          <th>Année</th>
          <th>Compétition</th>
        </tr>
      </thead>
      <tbody>
        {% for robot in robots %}
        <tr>
          <td>{{ robot.classement }}</td>
          <td class="robot-name"><a href="/robot/{{ robot.id }}" style="color: inherit; text-decoration: none;">{{ robot.nom }}</a></td>
          <td>{{ robot.annee }}</td>
          <td><span class="badge-FTC">{{ robot.competition }}</span></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</body>
</html>
