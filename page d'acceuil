<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RoboArchive — Archive FRC & ECAM</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css"/>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: #f5f5f3; color: #1a1a18; }

    /* Header */
    .header { background: white; padding: 1.5rem; border-bottom: 1px solid #e0ded8; }
    .logo { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; }
    .logo-icon { width: 60px; height: 60px; border-radius: 14px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #185FA5; }
    .logo-icon img { width: 100%; height: 100%; object-fit: contain; display: block; }
    .logo-icon i { font-size: 24px; color: #E6F1FB; }
    .logo-title { font-size: 18px; font-weight: 500; }
    .logo-sub { font-size: 13px; color: #888780; }
    .nav { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
    .nav-btn { font-size: 13px; padding: 6px 14px; border: 1px solid #d3d1c7; border-radius: 8px; background: transparent; color: #888780; cursor: pointer; text-decoration: none; }
    .nav-btn.active { background: #e6f1fb; color: #185FA5; border-color: transparent; }
    .nav-btn.login { margin-left: auto; border-color: #185FA5; color: #185FA5; }

    .year-filter { display: flex; flex-direction: column; align-items: flex-start; gap: 8px; padding: 0 1.5rem 1rem; }
    .year-title { font-size: 14px; margin-bottom: 4px; color: #55523f; font-weight: 600; }
    .year-btn { font-size: 12px; padding: 6px 12px; border: 1px solid #d3d1c7; border-radius: 999px; background: transparent; color: #888780; text-decoration: none; }
    .year-btn.active { background: #e6f1fb; color: #185FA5; border-color: transparent; }

    /* Stats */
    .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; padding: 1rem 1.5rem; }
    .stat { background: white; border-radius: 8px; padding: 10px 12px; }
    .stat-num { font-size: 22px; font-weight: 500; }
    .stat-label { font-size: 12px; color: #888780; margin-top: 2px; }

    /* Grille robots */
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; padding: 0 1.5rem 1.5rem; }
    .robot-card { background: white; border: 1px solid #e0ded8; border-radius: 12px; overflow: hidden; text-decoration: none; color: inherit; display: block; transition: border-color 0.15s; }
    .robot-card:hover { border-color: #b4b2a9; }
    .robot-img { width: 100%; height: 120px; background: #f1efe8; display: flex; align-items: center; justify-content: center; }
    .robot-img i { font-size: 40px; color: #888780; opacity: 0.4; }
    .robot-body { padding: 12px; }
    .robot-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 4px; }
    .robot-name { font-size: 14px; font-weight: 500; }
    .comp-badge { font-size: 11px; padding: 3px 10px; border-radius: 20px; font-weight: 500; }
    .badge-FRC  { background: #E6F1FB; color: #0C447C; }
    .badge-FTC  { background: #FFF3E0; color: #E65100; }
    .badge-ECAM { background: #EAF3DE; color: #27500A; }
    .robot-meta { font-size: 12px; color: #888780; display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
    .robot-team { font-size: 12px; color: #888780; display: flex; align-items: center; gap: 4px; }
    .rank { display: flex; align-items: center; gap: 4px; font-size: 12px; margin-top: 6px; }
    .rank i { font-size: 14px; color: #BA7517; }
    .rank span { color: #888780; }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="header">
    <div class="logo">
      <div class="logo-icon">
        <img src="{{ url_for('template_logo') }}" alt="Logo RoboArchive" onerror="this.style.display='none'" />
      </div>
      <div>
        <div class="logo-title">RoboArchive</div>
        <div class="logo-sub">Archive FTC & ECAM</div>
      </div>
    </div>
    <div class="nav">
      <a href="/" class="nav-btn active">Tous les robots</a>
      <a href="/classements" class="nav-btn">Classements</a>
      <a href="#" class="nav-btn">Équipes</a>
      <a href="#" class="nav-btn login">Connexion équipe</a>
    </div>
    <div class="year-filter">
      <div class="year-title">Années</div>
      <a href="/" class="year-btn {% if not selected_year %}active{% endif %}">Tous</a>
      {% for year in years %}
      <a href="/?annee={{ year }}" class="year-btn {% if selected_year == year %}active{% endif %}">{{ year }}</a>
      {% endfor %}
    </div>
  </div>

  <!-- Stats -->
  <div class="stats">
    <div class="stat">
      <div class="stat-num">{{ robots | length }}</div>
      <div class="stat-label">Robots archivés</div>
    </div>
    <div class="stat">
      <div class="stat-num">{{ robots | map(attribute='equipe') | unique | list | length }}</div>
      <div class="stat-label">Équipes</div>
    </div>
    <div class="stat">
      <div class="stat-num">{{ robots | map(attribute='annee') | unique | list | length }}</div>
      <div class="stat-label">Années</div>
    </div>
  </div>

  <!-- Grille robots -->
  <div class="grid">

    {% for robot in robots %}
    <a href="/robot/{{ robot.id }}" class="robot-card">
      <div class="robot-img"><i class="ti ti-robot"></i></div>
      <div class="robot-body">
        <div class="robot-header">
          <div class="robot-name">{{ robot.nom }}</div>
          <span class="comp-badge badge-{{ robot.competition }}">{{ robot.competition }}</span>
        </div>
        <div class="robot-meta"><i class="ti ti-calendar" style="font-size:13px"></i> {{ robot.annee }}</div>
        <div class="robot-team"><i class="ti ti-users" style="font-size:13px"></i> {{ robot.equipe }}</div>
        <div class="rank"><i class="ti ti-trophy"></i><span>{{ robot.classement }}e place</span></div>
      </div>
    </a>
    {% endfor %}

  </div>

</body>
</html>
