<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Contacts anciens participants — RoboArchive</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css"/>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; background: linear-gradient(180deg, #e6efff 0%, #f7fbff 100%); color: #1a1a18; }
    .header { background: rgba(255,255,255,0.95); padding: 1.5rem; border-bottom: 1px solid #dbeafe; backdrop-filter: blur(10px); }
    .logo { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; }
    .logo-icon { width: 50px; height: 50px; border-radius: 16px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #0f3b7c; }
    .logo-icon img { width: 100%; height: 100%; object-fit: contain; display: block; }
    .logo-title { font-size: 18px; font-weight: 600; color: #0f3b7c; }
    .logo-sub { font-size: 13px; color: #475569; }
    .nav { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
    .nav-btn { font-size: 13px; padding: 8px 14px; border: 1px solid #cbd5e1; border-radius: 999px; background: #fff; color: #475569; text-decoration: none; }
    .nav-btn.active { background: #0f3b7c; color: #fff; border-color: transparent; }
    .content { max-width: 980px; margin: 1.5rem auto; padding: 0 1.5rem 1.5rem; }
    .hero { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 1rem; background: white; border: 1px solid #e5e7eb; border-radius: 24px; padding: 1.5rem; margin-bottom: 1.5rem; }
    .hero-title { font-size: 28px; font-weight: 700; }
    .hero-subtitle { color: #4b5563; font-size: 15px; max-width: 620px; line-height: 1.6; }
    .contact-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
    .contact-card { background: white; border: 1px solid #e5e7eb; border-radius: 24px; padding: 1.25rem; display: flex; flex-direction: column; gap: 0.75rem; }
    .contact-card h2 { font-size: 18px; margin: 0; }
    .contact-card .contact-role { color: #6b7280; font-size: 14px; }
    .contact-card .contact-detail { font-size: 14px; color: #374151; }
    .contact-card .contact-detail strong { color: #111827; }
    .contact-card .contact-actions { margin-top: auto; display: flex; justify-content: space-between; gap: 0.5rem; }
    .contact-button { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.7rem 0.95rem; border-radius: 999px; border: 1px solid #d1d5db; text-decoration: none; color: #374151; font-size: 13px; background: #fff; }
    .contact-button:hover { background: #f8fafc; }
  </style>
</head>
<body>
  <div class="header">
    <div class="logo">
      <div class="logo-icon">
        <img src="{{ url_for('template_logo') }}" alt="Logo RoboArchive" onerror="this.style.display='none'" />
      </div>
      <div>
        <div class="logo-title">RoboArchive</div>
        <div class="logo-sub">Archive FTC & ECAM</div>
      </div>
    </div>
    <div class="nav">
      <a href="/" class="nav-btn {% if active_page == 'home' %}active{% endif %}">Tous les robots</a>
      <a href="/classements" class="nav-btn {% if active_page == 'classements' %}active{% endif %}">Classements</a>
      <a href="/forum" class="nav-btn {% if active_page == 'forum' %}active{% endif %}">Forum</a>
      <a href="/contacts" class="nav-btn {% if active_page == 'contacts' %}active{% endif %}">Contacts</a>
    </div>
  </div>

  <div class="content">
    <div class="hero">
      <div>
        <div class="hero-title">Anciens participants</div>
        <div class="hero-subtitle">Retrouvez les contacts des anciens membres, pour échanger sur les projets de robotique, les compétitions et les conseils.</div>
      </div>
      <div class="hero-stats">
        <strong style="font-size: 24px; color: #111827;">{{ participants|length }}</strong>
        <div style="color: #6b7280; font-size: 13px;">anciens participants</div>
      </div>
    </div>

    <div class="contact-grid">
      {% for p in participants %}
      <div class="contact-card">
        <h2>{{ p.nom }}</h2>
        <div class="contact-role">{{ p.role }} · Promo {{ p.promo }}</div>
        <div class="contact-detail"><strong>Email :</strong> {{ p.email }}</div>
        <div class="contact-detail"><strong>Téléphone :</strong> {{ p.tel }}</div>
        <div class="contact-actions">
          <a class="contact-button" href="mailto:{{ p.email }}"><i class="ti ti-mail"></i> Envoyer un mail</a>
          <a class="contact-button" href="tel:{{ p.tel }}"><i class="ti ti-phone"></i> Appeler</a>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</body>
</html>
